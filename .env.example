# ── GitHub Models (free, instant — recommended for the demo) ──────────────────
# 1. Go to https://github.com/settings/tokens → Generate new token (classic)
# 2. No scopes needed — just create and copy the token
GITHUB_TOKEN=your_github_pat_here

# Model provider: "github" or "azure"
MODEL_PROVIDER=github

# ── Azure AI Foundry (hot-swap — stronger eligibility story) ──────────────────
# Uncomment and fill these, then set MODEL_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your_azure_key_here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
